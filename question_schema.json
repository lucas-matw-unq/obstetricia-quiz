{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Obstetrics Question Schema",
  "type": "object",
  "required": ["question", "options", "correct_index", "correct_letter", "topic", "difficulty", "source_info", "id"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the question."
    },
    "question": {
      "type": "string",
      "description": "The text of the question."
    },
    "options": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 4,
      "maxItems": 4,
      "description": "The four possible multiple-choice answers."
    },
    "correct_index": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "description": "The zero-based index of the correct option."
    },
    "correct_letter": {
      "type": "string",
      "enum": ["A", "B", "C", "D"],
      "description": "The letter corresponding to the correct answer."
    },
    "topic": {
      "type": "string",
      "description": "The medical topic classification."
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "The difficulty level (1-5)."
    },
    "source_info": {
      "type": "object",
      "required": ["source_name", "text_excerpt"],
      "properties": {
        "source_name": {
          "type": "string",
          "description": "The name of the source file or collection (e.g., 'choices_1_300', '19. 1CESAREA. DRA. CEPEDA.pdf')."
        },
        "text_excerpt": {
          "type": "string",
          "description": "The specific text or citation from the source that supports the question/answer."
        },
        "page_number": {
          "type": "integer",
          "description": "The page number in the source document, if applicable."
        },
        "file_path": {
          "type": "string",
          "description": "The path to the source file within the repository."
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional additional question-level metadata.",
      "properties": {
        "last_reviewed": { "type": "string", "format": "date" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
